# Copy this file to .env on the server and fill in real values.
# NEVER commit .env to git.

# Strong password for PostgreSQL — change this!
POSTGRES_PASSWORD=changeme_strong_password_here

# Dashboard login password (shown on the login screen)
DASHBOARD_PASSWORD=changeme_dashboard_password

# Secret key for signing JWT tokens — generate with: openssl rand -hex 32
JWT_SECRET=changeme_very_long_random_string_here
